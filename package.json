{
  "name": "cheese-library",
  "version": "1.1.0",
  "description": "Single page app to look up cheese information",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.80.0",
    "@payloadcms/next": "3.80.0",
    "@payloadcms/payload-cloud": "3.80.0",
    "@payloadcms/richtext-lexical": "3.80.0",
    "@payloadcms/translations": "3.80.0",
    "@payloadcms/ui": "3.80.0",
    "@tailwindcss/vite": "^4.2.2",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.13.2",
    "next": "^16.2.3",
    "payload": "3.80.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "0.34.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "^15.5.15",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "^22.19.17",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.4.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "26.1.0",
    "playwright": "1.58.2",
    "playwright-core": "1.58.2",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=24.13.1 <25.0.0",
    "pnpm": "^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
